# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://PROJECT_ID.supabase.co
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_BUCKET=rupi-documents

# API Keys
OPENAI_API_KEY=

# Application
LOG_LEVEL=INFO
DEBUG=false
ENVIRONMENT=development

# Document Fetching
DOCUMENT_FETCH_TIMEOUT=30
DOCUMENT_FETCH_RETRIES=3

# File Storage
DOCUMENTS_STORAGE_PATH=./tax-docs
TEMP_UPLOAD_PATH=./temp_uploads

# OCR Configuration
TESSERACT_PATH=

# Scheduler
SCHEDULER_TIMEZONE=Asia/Kolkata

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24